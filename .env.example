# Core APK/Appium configuration
APP_PATH=app/app-under-test.apk
APPIUM_SERVER_URL=http://127.0.0.1:4723
ANDROID_PLATFORM_VERSION=
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_UDID=
ANDROID_APP_PACKAGE=
ANDROID_APP_ACTIVITY=
NO_RESET=false
FULL_RESET=false
AUTO_GRANT_PERMISSIONS=true
NEW_COMMAND_TIMEOUT=300

# Test data and locator overrides for APK-only automation
TEST_USERNAME=qa.user@example.com
TEST_PASSWORD=change-me
LOGIN_USERNAME_LOCATOR=id:com.example.app:id/email
LOGIN_PASSWORD_LOCATOR=id:com.example.app:id/password
LOGIN_SUBMIT_LOCATOR=id:com.example.app:id/login
HOME_READY_LOCATOR=xpath://android.widget.TextView[contains(@text,'Home')]

# Jira integration. Leave ENABLE_JIRA=false for local experimentation.
ENABLE_JIRA=false
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=qa-automation@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=QA
JIRA_ISSUE_TYPE=Bug
JIRA_COMPONENT=Mobile Automation

# GitHub PR automation. Used only when tests pass and ENABLE_CREATE_PR=true.
ENABLE_CREATE_PR=false
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repository
GITHUB_BASE_BRANCH=main
GITHUB_HEAD_BRANCH=qa/mobile-test-results
GITHUB_PR_TITLE=Mobile QA automation passed

# Notifications
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=qa-automation@example.com
EMAIL_TO=

# Firebase Test Lab
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=
FIREBASE_DEVICE_MODEL=Pixel2
FIREBASE_DEVICE_VERSION=30
FIREBASE_DEVICE_LOCALE=en
FIREBASE_DEVICE_ORIENTATION=portrait
